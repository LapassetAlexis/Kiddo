{
  "expo": {
    "name": "KidPoints",
    "slug": "kidpoints",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "kidpoints",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#18181e"
    },
    "ios": { "supportsTablet": false, "bundleIdentifier": "com.kidpoints.app" },
    "android": { "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#18181e" }, "package": "com.kidpoints.app" },
    "plugins": ["expo-router", "expo-secure-store"]
  }
}
