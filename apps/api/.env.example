# Database
DATABASE_URL=postgresql://kidpoints:password@localhost:5432/kidpoints_dev

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh
